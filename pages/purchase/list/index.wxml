<view class="content">
  <view class="category-panel">
    <block wx:for="{{categories}}" wx:key="id">
      <view
        class="category-item {{activeCategoryId === item.id ? 'active' : ''}}"
        bindtap="handleCategoryChange"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </block>
  </view>

  <scroll-view
    class="product-panel"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="false"
    scroll-with-animation="true"
    scroll-into-view="{{scrollIntoViewId}}"
    bindscroll="handleProductScroll"
  >
    <view class="product-list">
      <block wx:for="{{groupedProducts}}" wx:key="id">
        <view class="category-section" id="cat-{{item.id}}" data-id="{{item.id}}">
          <view class="category-section-title">{{item.name}}</view>

          <block wx:for="{{item.products}}" wx:key="id">
            <view class="product-card" bindtap="handleTapProduct" data-id="{{item.id}}">
              <image class="product-image" src="{{item.cover}}" mode="aspectFill"></image>

              <view class="product-info">
                <view class="product-title-row">
                  <text class="product-name">{{item.name}}</text>
                  <text class="product-price">¥{{item.price}}</text>
                </view>

                <view class="meta-row">
                  <view class="tag-row">
                    <block wx:for="{{item.tags}}" wx:key="index">
                      <text class="tag">{{item}}</text>
                    </block>
                  </view>

                  <view
                    wx:if="{{(item.cartQuantity || 0) > 0}}"
                    class="quantity-stepper"
                    catchtap="noop"
                  >
                    <view
                      class="stepper-btn"
                      data-id="{{item.id}}"
                      data-quantity="{{item.cartQuantity || 0}}"
                      catchtap="handleDecreaseQuantity"
                    >-</view>
                    <text class="stepper-value">{{item.cartQuantity || 0}}</text>
                    <view
                      class="stepper-btn stepper-btn--plus"
                      data-id="{{item.id}}"
                      data-quantity="{{item.cartQuantity || 0}}"
                      catchtap="handleIncreaseQuantity"
                    >+</view>
                  </view>

                  <view
                    wx:else
                    class="stepper-btn stepper-btn--plus stepper-btn--single"
                    data-id="{{item.id}}"
                    data-quantity="{{item.cartQuantity || 0}}"
                    catchtap="handleIncreaseQuantity"
                  >+</view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
