.content {
  height: 100vh;
  display: flex;
  overflow: hidden;
}

/* 左侧分类 */
.category-panel {
  width: 170rpx;
  background: #f7f7f7;
  padding-top: 0rpx;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(0, 0, 0, 0.04);
}

.category-item {
  position: relative;
  padding: 28rpx 36rpx;
  font-size: 24rpx;
  color: #444;
  line-height: 1.2;
}

.category-item.active {
  background: #ffffff;
  color: #111;
  font-weight: 500;
}

.category-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #c8a97e;
}

/* 右侧产品区域 */
.product-panel {
  flex: 1;
  height: 100%;
  padding: 0 20rpx 0;
  box-sizing: border-box;
  background: #ffffff;
}

.product-panel::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.category-section {
  margin-bottom: 24rpx;
}

.category-section-title {
  position: sticky;
  top: 0;
  z-index: 5;
  background: #ffffff;
  padding: 8rpx 4rpx;
  font-size: 24rpx;
  color: #666;
}

/* 产品卡片 */
.product-card {
  background: #f5f8f6;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: #e8e6e2;
  display: block;
}

.product-info {
  padding: 10rpx 18rpx 14rpx;
  background: #f8f7f5;
}

.product-name-row {
  margin-bottom: 12rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 400;
  color: #222;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #eee7d9;
  color: #6a5b45;
  font-size: 22rpx;
  line-height: 34rpx;
}

