.content {
  height: 100%;
  display: flex;
  overflow: hidden;
}

.category-panel {
  width: 170rpx;
  background: #f7f7f7;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(0, 0, 0, 0.04);
}

.category-item {
  position: relative;
  padding: 28rpx 30rpx;
  font-size: 24rpx;
  color: #444;
  line-height: 1.3;
}

.category-item.active {
  background: #ffffff;
  color: #111;
  font-weight: 500;
}

.category-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #c8a97e;
}

.product-panel {
  flex: 1;
  height: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.product-panel::-webkit-scrollbar {
  width: 0;
  height: 0;
  display: none;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.category-section {
  margin-bottom: 24rpx;
}

.category-section-title {
  position: sticky;
  top: 0;
  z-index: 5;
  background: #ffffff;
  padding: 10rpx 4rpx;
  font-size: 24rpx;
  color: #666;
}

.product-card {
  background: #f7f5f1;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.product-image {
  width: 100%;
  height: 250rpx;
  background: #e8e6e2;
  display: block;
}

.product-info {
  padding: 18rpx;
  background: #fffdf9;
}

.product-title-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.product-name {
  flex: 1;
  font-size: 26rpx;
  color: #222;
  line-height: 1.45;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #a52f1d;
}

.meta-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tag-row {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #eee7d9;
  color: #6a5b45;
  font-size: 18rpx;
  line-height: 26rpx;
}

.quantity-stepper {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 5rpx;
  border-radius: 999rpx;
  background: #f3eee7;
}

.stepper-btn {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #58483a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.stepper-btn--plus {
  background: #a52f1d;
  color: #ffffff;
}

.stepper-btn--single {
  width: 42rpx;
  height: 42rpx;
}

.stepper-value {
  min-width: 34rpx;
  text-align: center;
  font-size: 22rpx;
  color: #2f261f;
}
