<view class="detail-mask" wx:if="{{show}}" bindtap="handleClose">
  <view class="detail-popup" catchtap="noop">
    <view class="close-btn floating" bindtap="handleClose">&#215;</view>

    <swiper
      class="detail-swiper"
      circular="true"
      indicator-dots="true"
      autoplay="false"
      bindchange="handleSwiperChange"
    >
      <block wx:for="{{detailData.images}}" wx:key="index">
        <swiper-item>
          <image
            class="detail-image"
            src="{{item}}"
            mode="aspectFill"
            bindtap="handlePreviewImage"
            data-current="{{item}}"
          ></image>
        </swiper-item>
      </block>
    </swiper>

    <scroll-view class="detail-content" scroll-y="true" show-scrollbar="false">
      <view class="detail-body">
        <view class="detail-top">
          <view>
            <view class="detail-name">{{detailData.name}}</view>
            <view class="tag-row detail-tags">
              <block wx:for="{{detailData.tags}}" wx:key="index">
                <text class="tag">{{item}}</text>
              </block>
            </view>
          </view>
          <text class="detail-price">&#165;{{detailData.price}}</text>
        </view>

        <view class="detail-desc">{{detailData.desc}}</view>

        <view class="detail-block">
          <view class="detail-block-title">选择规格</view>
          <view class="option-row">
            <block wx:for="{{detailData.sizes}}" wx:key="index">
              <view
                class="option-chip {{selectedSize === item ? 'selected' : ''}}"
                bindtap="handleSelectSize"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </block>
          </view>
        </view>

        <view class="detail-block">
          <view class="detail-block-title">选择颜色</view>
          <view class="option-row">
            <block wx:for="{{detailData.colors}}" wx:key="index">
              <view
                class="option-chip {{selectedColor === item ? 'selected' : ''}}"
                bindtap="handleSelectColor"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </block>
          </view>
        </view>

        <view class="detail-block detail-block--qty">
          <view class="detail-block-title">购买数量</view>
          <view class="quantity-stepper">
            <view class="stepper-btn" bindtap="handleDecreaseQuantity">-</view>
            <text class="stepper-value">{{quantity}}</text>
            <view class="stepper-btn stepper-btn--plus" bindtap="handleIncreaseQuantity">+</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="action-bar">
      <view class="action-summary">
        <text class="action-price">&#165;{{detailData.price}}</text>
        <text class="action-note">已选 {{quantity}} 件</text>
      </view>
      <view class="action-btn action-btn--ghost" bindtap="handleAddToCart">加入购物车</view>
      <view class="action-btn action-btn--solid" bindtap="handleBuyNow">立即购买</view>
    </view>
  </view>
</view>
