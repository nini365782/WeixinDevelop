.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}

.detail-popup {
  width: 100%;
  height: 88vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.close-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.18);
  color: #fff;
  font-size: 34rpx;
  line-height: 44rpx;
  text-align: center;
}

.close-btn.floating {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 10;
}

/* 轮播图 */
.detail-swiper {
  width: 100%;
  height: 420rpx;
  background: #f2f2f2;
}

.detail-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 详情滚动区 */
.detail-content {
  flex: 1;
  background: #fff;
}

.detail-body {
  padding: 28rpx;
  box-sizing: border-box;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.detail-tags {
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #efefef;
}

.detail-block {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #efefef;
}

.detail-block-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 18rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-chip {
  min-width: 120rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.option-chip.selected {
  background: #e9dfcf;
  color: #5f4b31;
  border: 1rpx solid #ccb18b;
}

