.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 999;
}

.detail-popup {
  width: 100%;
  height: 88vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.close-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  color: #fff;
  font-size: 34rpx;
  line-height: 52rpx;
  text-align: center;
}

.close-btn.floating {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  z-index: 10;
}

.detail-swiper {
  width: 100%;
  height: 420rpx;
  background: #f2f2f2;
}

.detail-image {
  width: 100%;
  height: 100%;
  display: block;
}

.detail-content {
  flex: 1;
  background: #fff;
}

.detail-body {
  padding: 28rpx;
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

.detail-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.detail-price {
  font-size: 38rpx;
  font-weight: 700;
  color: #a52f1d;
}

.detail-tags {
  margin-bottom: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 30rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #eee7d9;
  color: #6a5b45;
  font-size: 22rpx;
  line-height: 34rpx;
}

.detail-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #efefef;
}

.detail-block {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #efefef;
}

.detail-block--qty {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-block-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 18rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-chip {
  min-width: 120rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 10rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.option-chip.selected {
  background: #e9dfcf;
  color: #5f4b31;
  border: 1rpx solid #ccb18b;
}

.quantity-stepper {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #f4efe8;
}

.stepper-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #594a3d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.stepper-btn--plus {
  background: #a52f1d;
  color: #fff;
}

.stepper-value {
  min-width: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #2f261f;
}

.action-bar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 30rpx rgba(64, 48, 37, 0.06);
}

.action-summary {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.action-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #a52f1d;
}

.action-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8c7b6f;
}

.action-btn {
  min-width: 176rpx;
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.action-btn--ghost {
  background: #f2ece5;
  color: #5c4d40;
}

.action-btn--solid {
  background: #a52f1d;
  color: #ffffff;
}
