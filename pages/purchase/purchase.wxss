/* pages/product.wxss */
page {
    height: 100%;
    background: #f7f4ef;
    overflow: hidden;
  }
  
  .page {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f7f4ef;
    color: #222;
  }
  
  /* 主体 */
  .content {
    flex: 1;
    display: flex;
    overflow: hidden;
  }
  
  /* 左侧分类 */
  .category-panel {
    width: 170rpx;
    background: #f7f7f7;
    padding-top: 0rpx;
    box-sizing: border-box;
    border-right: 1rpx solid rgba(0, 0, 0, 0.04);
  }
  
  .category-item {
    position: relative;
    padding: 28rpx 36rpx;
    font-size: 24rpx;
    color: #444;
    line-height: 1.2;
  }
  
  .category-item.active {
    background: #ffffff;
    color: #111;
    font-weight: 500;
  }
  
  .category-item.active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 22rpx;
    bottom: 22rpx;
    width: 6rpx;
    border-radius: 0 6rpx 6rpx 0;
    background: #c8a97e;
  }
  
  /* 右侧产品区域 */
  .product-panel {
    flex: 1;
    height: 100%;
    padding: 0 20rpx 0;
    box-sizing: border-box;
    background: #ffffff;
  }

  .product-panel::-webkit-scrollbar {
    width: 0;
    height: 0;
    display: none;
  }
  
  .product-top-wrap {
    width: 100%;
    height: 30rpx;
    background: rgb(255, 255, 255);
    display: flex;
    align-items: center;
    padding: 0 20rpx;
    box-sizing: border-box;
    margin-bottom: 16rpx;
  }
  
  .product-section-title {
    font-size: 22rpx;
    color: #666;
    line-height: 1;
  }
  
  .product-top-bg {
    width: 100%;
    height: 44rpx;
    background: #ffffff;
    border-radius: 0;
  }
  
  .product-list {
    display: flex;
    flex-direction: column;
    gap: 18rpx;
  }

  .category-section {
    margin-bottom: 24rpx;
  }

  .category-section-title {
    position: sticky;
    top: 0;
    z-index: 5;
    background: #ffffff;
    padding: 8rpx 4rpx;
    font-size: 24rpx;
    color: #666;
  }
  
  /* 产品卡片 */
  .product-card {
    background: #f5f8f6;
    border: 1rpx solid rgba(0, 0, 0, 0.05);
    border-radius: 20rpx;
    overflow: hidden;
    margin-bottom: 18rpx;
  }
  
  .product-image {
    width: 100%;
    height: 240rpx;
    background: #e8e6e2;
    display: block;
  }
  
  .product-info {
    padding: 10rpx 18rpx 14rpx;
    background: #f8f7f5;
  }
  
  .product-name-row {
    margin-bottom: 12rpx;
  }
  
  .product-name {
    font-size: 26rpx;
    font-weight: 400;
    color: #222;
  }
  
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
  }
  
  .tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 30rpx;
    padding: 0 12rpx;
    border-radius: 8rpx;
    background: #eee7d9;
    color: #6a5b45;
    font-size: 22rpx;
    line-height: 34rpx;
  }
  
  .bottom-space {
    height: 120rpx;
    background: #fff;
    border-radius: 20rpx 20rpx 0 0;
    margin-top: 8rpx;
  }
  
  /* 遮罩 */
  .detail-mask {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 999;
  }
  
  .detail-popup {
    width: 100%;
    height: 88vh;
    background: #fff;
    border-radius: 28rpx 28rpx 0 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  
  .detail-category {
    font-size: 24rpx;
    color: #666;
  }
  
  .close-btn {
    width: 44rpx;
    height: 44rpx;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.18);
    color: #fff;
    font-size: 34rpx;
    line-height: 44rpx;
    text-align: center;
  }
  
  .close-btn.floating {
    position: absolute;
    right: 24rpx;
    top: 24rpx;
    z-index: 10;
  }
  
  /* 轮播图 */
  .detail-swiper {
    width: 100%;
    height: 420rpx;
    background: #f2f2f2;
  }
  
  .detail-image {
    width: 100%;
    height: 100%;
    display: block;
  }
  
  /* 详情滚动区 */
  .detail-content {
    flex: 1;
    background: #fff;
  }
  
  .detail-body {
    padding: 28rpx;
    box-sizing: border-box;
  }
  
  .detail-name {
    font-size: 34rpx;
    font-weight: 600;
    color: #222;
    margin-bottom: 16rpx;
  }
  
  .detail-tags {
    margin-bottom: 20rpx;
  }
  
  .detail-desc {
    font-size: 24rpx;
    color: #666;
    line-height: 1.8;
    padding-bottom: 24rpx;
    border-bottom: 1rpx solid #efefef;
  }
  
  .detail-block {
    padding: 24rpx 0;
    border-bottom: 1rpx solid #efefef;
  }
  
  .detail-block-title {
    font-size: 24rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 18rpx;
  }
  
  .option-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
  }
  
  .option-chip {
    min-width: 120rpx;
    height: 52rpx;
    padding: 0 20rpx;
    border-radius: 10rpx;
    background: #f5f5f5;
    color: #333;
    font-size: 22rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }
  
  .option-chip.selected {
    background: #e9dfcf;
    color: #5f4b31;
    border: 1rpx solid #ccb18b;
  }