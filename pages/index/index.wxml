<view class="page">
  <view class="hero">
    <view class="tag-wrap {{playEntranceMotion ? 'tag-wrap--motion' : ''}}">
      <view class="tag-rope"></view>
      <view class="tag-badge">
        <view class="tag-hole"></view>
        <image class="tag-image" src="/assets/images/logo.png" mode="widthFix"></image>
      </view>
    </view>

    <view class="hero-main">

    <view class="brand">
      <text class="brand-title">SLANDY</text>
      <text class="brand-subtitle">丝 · 兰 · 蒂</text>
    </view>

    <view class="hero-visual {{playEntranceMotion ? 'fade-in-up' : ''}}">
      <view class="hero-circle"></view>
      <image class="hero-bed" src="/assets/images/home-bed.png" mode="widthFix"></image>
    </view>

    <view class="hero-copy {{playEntranceMotion ? 'fade-in-up fade-in-up--delayed' : ''}}">
      <text class="hero-copy__en">REFINED HOME TEXTILES</text>
      <text class="hero-copy__cn">以自然为底色，以艺术为灵感，重塑家的柔软美学。</text>
    </view>
    </view>
  </view>

  <view class="content-card">
    <view class="action-group {{playEntranceMotion ? 'fade-in-up fade-in-up--delayed-2' : ''}}">
      <view class="action-button" hover-class="action-button--hover" hover-stay-time="120" bindtap="goToProduct">
        <image class="action-button__icon" src="/assets/images/home-producticon.png" mode="aspectFit"></image>
        <view class="action-button__text-row">
          <text class="action-button__text">进入产品系列</text>
          <text class="action-button__arrow">→</text>
        </view>
      </view>

      <view class="action-button" hover-class="action-button--hover" hover-stay-time="120" bindtap="goToPurchase">
        <image class="action-button__icon" src="/assets/images/home-purchaseicon.png" mode="aspectFit"></image>
        <view class="action-button__text-row">
          <text class="action-button__text">前往品牌商城</text>
          <text class="action-button__arrow">→</text>
        </view>
      </view>
    </view>

    <view class="section-head {{playEntranceMotion ? 'fade-in-up fade-in-up--delayed-2' : ''}}">
      <view class="section-head__title-wrap">
        <text class="section-head__title">最近上新</text>
        <view class="section-head__line"></view>
      </view>
      <text class="section-head__link" bindtap="goToProduct">查看更多</text>
    </view>

    <!-- Render home products from the showOnHome flag and keep horizontal scrolling. -->
    <scroll-view class="product-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="product-row">
        <block wx:for="{{featuredProducts}}" wx:key="id">
          <view
            class="product-card {{playEntranceMotion ? 'card-reveal' : ''}}"
            style="{{playEntranceMotion ? 'animation-delay: ' + (index * 90) + 'ms;' : ''}}"
            data-id="{{item.id}}"
            hover-class="product-card--hover"
            hover-stay-time="120"
            bindtap="handleOpenProductDetail"
          >
            <image class="product-card__image" src="{{item.cover}}" mode="aspectFill"></image>
            <text class="product-card__name">{{item.name}}</text>
            <text class="product-card__series">{{item.categoryName}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
</view>
