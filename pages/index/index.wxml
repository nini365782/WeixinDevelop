<view class="page">
  <image class="bg-image" src="/assets/images/home-bg.png" mode="aspectFill"></image>

  <view class="content">
    <view class="logo-wrap">
      <image class="logo" src="/assets/images/logo.png" mode="widthFix"></image>
    </view>

    <view class="intro-wrap">
      <text class="intro-text">我们专注于高品质家纺与家居软装。</text>
      <text class="intro-text">在产品页发现灵感，在商城页完成挑选与下单。</text>
    </view>

    <view class="action-group">
      <view class="enter-btn" bindtap="goToProduct">
        <text class="btn-text">进入产品页</text>
        <text class="btn-arrow">→</text>
      </view>

      <view class="enter-btn enter-btn--ghost" bindtap="goToPurchase">
        <text class="btn-text btn-text--dark">进入商城页</text>
        <text class="btn-arrow btn-arrow--dark">→</text>
      </view>
    </view>
  </view>
</view>
