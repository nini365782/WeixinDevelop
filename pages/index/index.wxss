page {
  height: 100%;
  background: transparent;
}

.page {
  position: relative;
  min-height: 80vh;
  overflow: hidden;
  background: transparent;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 100%;
}

.content {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 140rpx 100rpx calc(150rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  margin-top: 180rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo {
  width: 180rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.08));
}

.intro-wrap {
  margin-top: 50rpx;
  width: 100%;
  box-sizing: border-box;
}

.intro-text {
  display: block;
  text-align: center;
  font-size: 25rpx;
  line-height: 1.8;
  color: #1b1a19;
  letter-spacing: 1rpx;
}

.action-group {
  margin-top: 360rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.enter-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #52883c 0%, #5a9246 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 14rpx 30rpx rgba(97, 153, 77, 0.28);
}

.enter-btn--ghost {
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(88, 72, 58, 0.12);
  box-shadow: 0 14rpx 30rpx rgba(96, 82, 68, 0.10);
}

.btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.btn-text--dark {
  color: #2f261f;
}

.btn-arrow {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
}

.btn-arrow--dark {
  color: #2f261f;
}
