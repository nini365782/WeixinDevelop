  .content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    box-sizing: border-box;
    padding: 140rpx 100rpx 150rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .logo-wrap {
    margin-top: 40rpx;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .logo {
    width: 180rpx;
    filter: drop-shadow(0 8rpx 20rpx rgba(0, 0, 0, 0.08));
  }
  
  .intro-wrap {
    margin-top: 56rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  .intro-text {
    display: block;
    text-align: center;
    font-size: 25rpx;
    line-height: 1;
    color: #1b1a19;
    letter-spacing: 1rpx;
  }
  
  .enter-btn {
    margin-top: 450rpx;
    width: 400rpx;
    height: 96rpx;
    border-radius: 30rpx;
    background: linear-gradient(135deg, #52883c 0%, #5a9246 100%);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    font-size: 32rpx;
    font-weight: 600;
    box-shadow: 0 14rpx 30rpx rgba(97, 153, 77, 0.28);
    border: none;
    padding: 0;
  }

  
  .btn-text {
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 600;
    letter-spacing: 1rpx;
  }
  
  .btn-arrow {
    color: #ffffff;
    font-size: 34rpx;
    font-weight: 600;
    transform: translateY(1rpx);
  }
