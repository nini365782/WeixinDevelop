page {
  min-height: 100%;
  background: linear-gradient(180deg, #f7f7f5 0%, #f3f1ec 100%);
}

.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0) 28%),
    linear-gradient(180deg, #f7f7f5 0%, #f3f1ec 100%);
  overflow-x: hidden;
}

.hero {
  position: relative;
  margin: 0;
  padding: 48rpx 38rpx 180rpx;
  border-radius: 0;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.88) 0%, rgba(255, 255, 255, 0) 56%),
    linear-gradient(180deg, #f8f6d9 0%, #f7f6e6 100%);
  box-shadow: 0 10rpx 34rpx rgba(177, 178, 160, 0.18);
}

.tag-wrap {
  position: absolute;
  top: 70rpx;
  right: 65rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform-origin: center top;
  z-index: 3;
}

.tag-wrap--motion {
  animation: tag-sway 5.8s ease-in-out infinite;
}

.tag-rope {
  width: 2rpx;
  height: 214rpx;
  background: linear-gradient(180deg, rgba(192, 174, 108, 0.9) 0%, rgba(214, 196, 133, 0.62) 100%);
  box-shadow: 0 0 3rpx rgba(191, 174, 110, 0.18);
}

.tag-badge {
  position: relative;
  width: 96rpx;
  height: 126rpx;
  margin-top: -2rpx;
  border-radius: 48rpx;
  background: linear-gradient(180deg, #f3e4b7 0%, #ecd9a5 100%);
  box-shadow: 0 10rpx 16rpx rgba(195, 177, 111, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-hole {
  position: absolute;
  top: 12rpx;
  left: 50%;
  width: 12rpx;
  height: 12rpx;
  margin-left: -6rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
}

.tag-image {
  width: 80rpx;
  margin-top: 18rpx;
}

.hero-main {
  transform: translateY(50rpx);
}

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 88rpx;
  position: relative;
  z-index: 2;
}

.brand-title {
  font-size: 66rpx;
  line-height: 1;
  letter-spacing: 13rpx;
  color: #a6aa69;
  font-weight: 300;
  padding-left: 13rpx;
}

.brand-subtitle {
  margin-top: 26rpx;
  font-size: 30rpx;
  letter-spacing: 14rpx;
  color: #a6aa69;
  padding-left: 14rpx;
}

.hero-visual {
  position: relative;
  width: 100%;
  height: 430rpx;
  margin-top: 34rpx;
}

.hero-circle {
  position: absolute;
  left: 50%;
  bottom: 34rpx;
  width: 482rpx;
  height: 380rpx;
  margin-left: -241rpx;
  border-radius: 50%;
  background: #b2c294;
}

.hero-bed {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 610rpx;
  transform: translateX(-50%);
  filter: drop-shadow(0 28rpx 32rpx rgba(113, 110, 92, 0.18));
}

.hero-copy {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
}

.hero-copy__en {
  font-size: 22rpx;
  line-height: 1.4;
  color: #d2d0c0;
}

.hero-copy__cn {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #71815f;
}

.content-card {
  position: relative;
  margin-top: -25rpx;
  padding: 24rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 56rpx 56rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(247, 245, 242, 0.98) 100%);
  box-shadow: 0 -10rpx 24rpx rgba(255, 255, 255, 0.5);
}

.action-group {
  position: relative;
  z-index: 2;
  margin-top: -90rpx;
  display: flex;
  justify-content: space-between;
  padding: 0 36rpx;
}

.action-button {
  width: 324rpx;
  height: 170rpx;
  box-sizing: border-box;
  padding: 18rpx 24rpx 24rpx;
  border-radius: 10rpx;
  border: 1rpx solid #769b85;
  background: #ffffff;
  box-shadow: 0 8rpx 14rpx rgba(95, 120, 107, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.action-button--hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 18rpx rgba(95, 120, 107, 0.2);
}

.action-button__icon {
  width: 84rpx;
  height: 58rpx;
}

.action-button__text-row {
  position: relative;
  width: 100%;
  margin-top: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-button__text {
  font-size: 27rpx;
  font-weight: 600;
  color: #305f30;
  line-height: 1;
  text-align: center;
}

.action-button__arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 27rpx;
  color: #305f30;
  line-height: 1;
}

.section-head {
  margin-top: 40rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-head__title-wrap {
  display: flex;
  flex-direction: column;
}

.section-head__title {
  font-size: 26rpx;
  line-height: 1.1;
  color: #71815f;
  font-weight: 600;
}

.section-head__line {
  width: 54rpx;
  height: 5rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #b9c588;
}

.section-head__link {
  display: none;
  position: relative;
  top: -12rpx;
  font-size: 25rpx;
  color: #71815f;
  line-height: 1.3;
}

.product-scroll {
  margin-top: 22rpx;
  width: 100%;
  white-space: nowrap;
}

.product-row {
  display: inline-flex;
  width: max-content;
  gap: 18rpx;
  padding: 0 36rpx;
  box-sizing: border-box;
}

.product-card {
  width: 214rpx;
  flex-shrink: 0;
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;
  transition: transform 180ms ease, opacity 180ms ease;
}

.product-card--hover {
  transform: translateY(-4rpx);
}

.product-card__image {
  width: 214rpx;
  height: 214rpx;
  border-radius: 18rpx;
  background: #ebe8df;
}

.product-card__name {
  display: block;
  width: 100%;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #403a34;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-card__series {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #c0c0c0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fade-in-up {
  animation: fade-in-up 640ms ease both;
}

.fade-in-up--delayed {
  animation-delay: 120ms;
}

.fade-in-up--delayed-2 {
  animation-delay: 220ms;
}

.card-reveal {
  opacity: 0;
  animation: card-reveal 520ms ease forwards;
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes card-reveal {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes tag-sway {
  0% {
    transform: rotate(3deg) translateY(0);
  }

  18% {
    transform: rotate(-2.4deg) translateY(6rpx);
  }

  36% {
    transform: rotate(1.6deg) translateY(1rpx);
  }

  52% {
    transform: rotate(-1deg) translateY(4rpx);
  }

  68% {
    transform: rotate(0.7deg) translateY(1rpx);
  }

  84% {
    transform: rotate(-0.35deg) translateY(3rpx);
  }

  100% {
    transform: rotate(3deg) translateY(0);
  }
}
