/**index.wxss**/
page {
    height: 100%;
    background: #f7f4ef;
  }
  
  .page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: linear-gradient(180deg, #f8f6f2 0%, #f5f1ea 100%);
  }
  
  .bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  
