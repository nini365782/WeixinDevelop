.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(243, 232, 219, 0.9) 0%, rgba(243, 232, 219, 0) 30%),
    #f8f5f1;
}

.hero-card {
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f3ede6 100%);
  box-shadow: 0 18rpx 40rpx rgba(85, 65, 49, 0.08);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f261f;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #7b6e61;
}

.section {
  margin-top: 28rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 32rpx rgba(85, 65, 49, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #efe7dd;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  font-size: 28rpx;
  color: #312821;
}

.menu-arrow {
  font-size: 28rpx;
  color: #a59482;
}
