<view class="page">
  <view class="hero-card">
    <text class="hero-title">我的订单</text>
    <text class="hero-subtitle">订单流程入口已经准备好，后续可继续接入真实下单状态。</text>
  </view>

  <view class="section">
    <block wx:for="{{sections}}" wx:key="title">
      <view class="order-item">
        <text class="order-title">{{item.title}}</text>
        <text class="order-desc">{{item.desc}}</text>
      </view>
    </block>
  </view>
</view>
