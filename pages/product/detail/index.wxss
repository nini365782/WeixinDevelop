.page {
  min-height: 100vh;
  background: #ffffff;
  color: #2d261f;
}

.media {
  position: relative;
}

.hero-swiper {
  width: 100%;
  height: 1020rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.media-actions {
  position: fixed;
  top: 104rpx;
  left: 24rpx;
  z-index: 20;
}

.floating-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 45rpx;
  color: #46392f;
  padding-bottom: 6rpx;
  box-shadow: 0 10rpx 30rpx rgba(62, 49, 38, 0.12);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.floating-btn__icon {
  width: 32rpx;
  height: 32rpx;
}

.sheet {
  margin-top: 0rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  padding: 20rpx 24rpx 48rpx;
}

.info-head {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.info-copy {
  flex: 1;
}

.product-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f1ece5;
  color: #6c5d4e;
  font-size: 22rpx;
}

.info-actions {
  display: flex;
  gap: 14rpx;
}

.icon-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #4f4337;
  box-shadow: 0 12rpx 28rpx rgba(89, 67, 51, 0.08);
}

.icon-btn__icon {
  width: 34rpx;
  height: 34rpx;
}

.favorite-glyph-detail {
  width: 36rpx;
  height: 36rpx;
  color: #4f4337;
}

.icon-btn--active {
  background: rgba(146, 63, 54, 0.94);
  color: #fff4f1;
}

.icon-btn--active .favorite-glyph-detail {
  color: #fff4f1;
}

.module {
  margin-top: 34rpx;
}

.module-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #3f342c;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-width: 112rpx;
  padding: 14rpx 20rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #f5f2ee;
  color: #6f6458;
  font-size: 24rpx;
}

.spec-card {
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #fbfaf8;
  border: 2rpx solid #f0e7dc;
}

.spec-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.spec-title {
  font-size: 28rpx;
  font-weight: 600;
}

.spec-line {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6f6257;
}

.desc,
.story {
  display: block;
  font-size: 24rpx;
  line-height: 1.9;
  color: #61554a;
}

.story {
  margin-top: 18rpx;
}

.fallback {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.fallback-text {
  font-size: 30rpx;
  color: #6f6459;
}
