.page {
  min-height: 100vh;
  background: #ffffff;
  color: #2d261f;
}

.media {
  position: relative;
}

.hero-swiper {
  width: 100%;
  height: 950rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.media-actions {
  position: fixed;
  top: 104rpx;
  left: 24rpx;
  z-index: 20;
}

.floating-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.52);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(62, 49, 38, 0.12);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.floating-btn__icon {
  width: 32rpx;
  height: 32rpx;
}

.sheet {
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  padding: 20rpx 24rpx 48rpx;
}

.info-head {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
}

.info-copy {
  flex: 1;
}

.product-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.series-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.product-series {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f1e6;
  font-size: 22rpx;
  line-height: 1.2;
  color: #574f3d;
}

.series-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f1e6;
  font-size: 22rpx;
  line-height: 1.2;
  color: #574f3d;
}

.info-actions {
  display: flex;
  gap: 14rpx;
}

.icon-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(89, 67, 51, 0.08);
}

.icon-btn__icon {
  width: 34rpx;
  height: 34rpx;
}

.share-glyph {
  color: #4f4337;
}

.favorite-glyph-detail {
  width: 36rpx;
  height: 36rpx;
  color: #4f4337;
}

.icon-btn--active {
  background: rgba(255, 255, 255, 0.96);
}

.favorite-glyph-detail--active {
  color: #c53b2a;
}

.module {
  margin-top: 60rpx;
  padding-top: 38rpx;
  border-top: 2rpx solid #f1f1f1;
}

.module-heading {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 34rpx;
}

.module-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
}

.module-title-en {
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: #cfd5df;
}

.palette-row {
  display: flex;
  flex-wrap: wrap;
  gap: 36rpx;
}

.palette-item {
  width: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.palette-swatch {
  width: 56rpx;
  height: 56rpx;
  padding: 4rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 0 2rpx rgba(232, 234, 239, 0.9);
  box-sizing: border-box;
}

.palette-swatch__inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.palette-name {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #8e94a1;
  line-height: 1.3;
}

.spec-table {
  width: 100%;
}

.spec-table__header,
.spec-table__row {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1.2fr;
  column-gap: 30rpx;
  align-items: center;
}

.spec-table__header {
  position: relative;
  padding: 0 0 28rpx;
}

.spec-table__header::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  height: 1rpx;
  background: #efefef;
}

.spec-table__row {
  padding: 22rpx 0;
}

.spec-table__label {
  font-size: 24rpx;
  color: #b3aeb9;
  padding-left: 30rpx;
  box-sizing: border-box;
}

.spec-table__col-title {
  text-align: center;
  font-size: 24rpx;
  font-weight: 400;
  color: #000000;
}

.spec-table__value {
  text-align: center;
  font-size: 26rpx;
  color: #6c7382;
}

.desc,
.story {
  display: block;
  font-size: 26rpx;
  line-height: 2.1;
  color: #7d8596;
}

.desc--full {
  margin-top: 6rpx;
}

.story {
  margin-top: 22rpx;
}

.fallback {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.fallback-text {
  font-size: 30rpx;
  color: #6f6459;
}
