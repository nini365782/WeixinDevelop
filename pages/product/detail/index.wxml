<view wx:if="{{product}}" class="page">
  <view class="media">
    <swiper class="hero-swiper" circular="true" indicator-dots="true" autoplay="false">
      <block wx:for="{{product.images}}" wx:key="index">
        <swiper-item>
          <image
            class="hero-image"
            src="{{item}}"
            mode="aspectFill"
            data-current="{{item}}"
            bindtap="handlePreviewImage"
          ></image>
        </swiper-item>
      </block>
    </swiper>

    <view class="media-actions">
      <view class="floating-btn" bindtap="handleBack">
        <image class="floating-btn__icon" src="/assets/icons/arrow-left.svg" mode="aspectFit"></image>
      </view>
    </view>
  </view>

  <view class="sheet">
    <view class="info-head">
      <view class="info-copy">
        <text class="product-name">{{product.name}}</text>
        <view class="series-row">
          <text class="product-series">{{product.categoryName}}</text>
          <block wx:for="{{product.tags}}" wx:key="index">
            <text class="series-tag">{{item}}</text>
          </block>
        </view>
      </view>

      <view class="info-actions">
        <view class="icon-btn {{isFavorite ? 'icon-btn--active' : ''}}" bindtap="handleToggleFavorite">
          <view class="{{isFavorite ? 'mdi-light--heart-solid favorite-glyph-detail favorite-glyph-detail--active' : 'mdi-light--heart favorite-glyph-detail'}}"></view>
        </view>
        <view class="icon-btn" bindtap="handleShareTap">
          <view class="material-symbols-light--share-outline icon-btn__icon share-glyph"></view>
        </view>
      </view>
    </view>

    <view class="module">
      <view class="module-heading">
        <text class="module-title">选色展示</text>
        <text class="module-title-en">SELECTED PALETTE</text>
      </view>
      <view class="palette-row">
        <block wx:for="{{product.colorPalette}}" wx:key="name">
          <view class="palette-item">
            <view class="palette-swatch">
              <view class="palette-swatch__inner" style="{{item.swatchStyle}}"></view>
            </view>
            <text class="palette-name">{{item.name}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="module">
      <view class="module-heading">
        <text class="module-title">规格参数</text>
        <text class="module-title-en">SPECIFICATIONS</text>
      </view>
      <view class="spec-table">
        <view class="spec-table__header">
          <text class="spec-table__label"></text>
          <block wx:for="{{product.specColumns}}" wx:key="index">
            <text class="spec-table__col-title">{{item}}</text>
          </block>
        </view>
        <block wx:for="{{product.specRows}}" wx:key="label">
          <view class="spec-table__row">
            <text class="spec-table__label">{{item.label}}</text>
            <block wx:for="{{item.values}}" wx:key="index">
              <text class="spec-table__value">{{item}}</text>
            </block>
          </view>
        </block>
      </view>
    </view>

    <view class="module">
      <view class="module-heading">
        <text class="module-title">详情介绍</text>
        <text class="module-title-en">DESCRIPTION</text>
      </view>
      <text class="desc desc--full">{{product.desc}} {{product.story}}</text>
    </view>
  </view>
</view>

<view wx:else class="fallback">
  <text class="fallback-text">未找到该商品</text>
</view>
