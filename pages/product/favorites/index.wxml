<view class="page">
  <view wx:if="{{!isEmpty}}" class="grid">
    <view class="toolbar">
      <text class="toolbar-count">已收藏 {{favoriteCount}} 件</text>
      <view class="toolbar-clear" bindtap="handleClearFavorites">清空</view>
    </view>
    <block wx:for="{{products}}" wx:key="id">
      <view class="product-card" data-id="{{item.id}}" bindtap="handleOpenDetail">
        <view class="image-wrap">
          <image class="product-image" src="{{item.cover}}" mode="aspectFill"></image>
          <view class="favorite-btn" data-id="{{item.id}}" catchtap="handleToggleFavorite">
            <view class="mdi-light--heart-solid favorite-glyph-favorites favorite-glyph-favorites--active"></view>
          </view>
        </view>
        <view class="product-meta">
          <text class="product-name">{{item.name}}</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-heart">
      <view class="mdi-light--heart empty-heart__icon"></view>
    </view>
    <text class="empty-title">暂无收藏商品</text>
    <text class="empty-desc">逛逛产品页，把喜欢的家居好物先收藏起来。</text>
  </view>
</view>
