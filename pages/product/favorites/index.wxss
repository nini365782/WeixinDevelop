.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, #f7eadf 0%, rgba(247, 234, 223, 0) 32%),
    #f6f2ec;
  padding: 24rpx 24rpx 40rpx;
  color: #2f261f;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.toolbar {
  width: 100%;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toolbar-count {
  font-size: 24rpx;
  color: #7b6d61;
}

.toolbar-clear {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  color: #8f5a50;
}

.product-card {
  width: 342rpx;
  margin-bottom: 34rpx;
  background: #ffffff;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(31, 36, 48, 0.06);
}

.image-wrap {
  position: relative;
  background: #efefef;
  line-height: 0;
}

.product-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

.favorite-btn {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.favorite-glyph-favorites {
  width: 28rpx;
  height: 28rpx;
}

.favorite-glyph-favorites--active {
  color: #c53b2a;
}

.product-meta {
  padding: 18rpx 20rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  background: #ffffff;
}

.product-name {
  font-size: 26rpx;
  line-height: 1.35;
  color: #111111;
}

.empty-state {
  min-height: 76vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-heart {
  width: 168rpx;
  height: 168rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.84);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 88rpx;
  color: #bea790;
  box-shadow: 0 20rpx 44rpx rgba(86, 66, 53, 0.08);
}

.empty-heart__icon {
  width: 88rpx;
  height: 88rpx;
  color: #bea790;
}

.empty-title {
  margin-top: 30rpx;
  font-size: 32rpx;
  color: #3d322a;
}

.empty-desc {
  margin-top: 12rpx;
  width: 420rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #85796d;
}
