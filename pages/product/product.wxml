<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-action" bindtap="handleOpenFavorites">
        <view class="mdi-light--heart favorite-glyph favorite-glyph--hero"></view>
      </view>
      <view class="search-wrap">
        <view class="search-icon material-symbols-light--search-rounded"></view>
        <input
          class="search-input"
          placeholder="搜索心仪的商品"
          placeholder-class="search-placeholder"
          confirm-type="search"
          value="{{searchValue}}"
          bindinput="handleSearchInput"
          bindconfirm="handleConfirmSearch"
        />
      </view>
    </view>

    <scroll-view class="category-scroll" scroll-x="true" show-scrollbar="false">
      <view class="category-row">
        <block wx:for="{{categories}}" wx:key="id">
          <view
            class="category-chip {{activeCategoryId === item.id ? 'category-chip--active' : ''}}"
            data-id="{{item.id}}"
            bindtap="handleCategoryTap"
          >
            {{item.name}}
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="content" scroll-y="true" enhanced="true" show-scrollbar="false">
    <view wx:if="{{!isEmpty}}" class="product-grid">
      <block wx:for="{{products}}" wx:key="id">
        <view class="product-card" data-id="{{item.id}}" bindtap="handleOpenDetail">
          <view class="image-wrap">
            <image class="product-image" src="{{item.cover}}" mode="aspectFill"></image>
            <view
              class="favorite-btn {{item.isFavorite ? 'favorite-btn--active' : ''}}"
              data-id="{{item.id}}"
              catchtap="handleToggleFavorite"
            >
              <view class="{{item.isFavorite ? 'mdi-light--heart-solid favorite-glyph favorite-glyph--active' : 'mdi-light--heart favorite-glyph'}}"></view>
            </view>
          </view>

          <view class="product-meta">
            <text class="product-name">{{item.name}}</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:else class="empty-state">
      <view class="empty-visual"></view>
      <text class="empty-title">暂无相关商品</text>
      <text class="empty-desc">换个关键词，或切换系列继续看看。</text>
    </view>
  </scroll-view>
</view>
